# Public Expo env vars are exposed to the app at build time.
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_FEED_URL=https://jsonplaceholder.typicode.com/posts

# Development defaults to the offline mock APIs.
EXPO_PUBLIC_USE_REAL_API=false

# Build-time brand selection. Supported values: ckpc, acme.
APP_BRAND=ckpc
