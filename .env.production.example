# Public Expo env vars are exposed to the app at build time.
EXPO_PUBLIC_APP_ENV=production
EXPO_PUBLIC_API_URL=https://api.cpkc.example.com
EXPO_PUBLIC_FEED_URL=https://api.cpkc.example.com/home/feed

# Production should call real hosted APIs.
EXPO_PUBLIC_USE_REAL_API=true

# Build-time brand selection. Supported values: cpkc, acme.
APP_BRAND=cpkc
