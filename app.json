{
  "expo": {
    "name": "CKPC RN Architecture",
    "slug": "ckpc-rn-architecture",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ckpcrn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ckpc.rnarchitecture"
    },
    "android": {
      "package": "com.ckpc.rnarchitecture"
    },
    "plugins": [
      "expo-localization",
      "expo-secure-store"
    ]
  }
}
